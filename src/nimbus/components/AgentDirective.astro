---
interface Props {
  /** Absolute or site-relative URL for this page's markdown version. */
  markdownUrl: string;
  /** Absolute or site-relative URL for the top-level llms.txt index. */
  llmsUrl: string;
}

const { markdownUrl, llmsUrl } = Astro.props;
---

<aside class="sr-only" data-ai-agent-directive>
  This page is available in Markdown format. Markdown is recommended for AI
  consumption. See <a href={markdownUrl}>{markdownUrl}</a> for this page, or
  <a href={llmsUrl}>{llmsUrl}</a> for the full documentation index.
</aside>
