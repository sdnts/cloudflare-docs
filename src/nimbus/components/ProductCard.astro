---
import { Icon } from "astro-icon/components";

type Category = "compute" | "ai" | "storage" | "media" | "zero-trust";

interface Props {
	icon: string;
	product: string;
	scenario: string;
	detail: string;
	href: string;
	cta?: string;
	category?: Category;
}

const {
	icon,
	product,
	scenario,
	detail,
	href,
	cta = "Get started",
	category,
} = Astro.props;

const CATEGORY_COLOR: Record<Category, string> = {
	compute: "#0a95ff",
	ai: "#19e306",
	storage: "#ee0ddb",
	media: "#9616ff",
	"zero-trust": "#009788",
};

// Per-card accent (category colour or brand), consumed by the hover rule.
const cardColor = category ? CATEGORY_COLOR[category] : "var(--color-primary)";
---

<a
	href={href}
	style={`--card-color: ${cardColor};`}
	class="group/product-card bg-background hover:bg-background/90 focus-visible:outline-primary relative flex flex-1 flex-col p-6 no-underline focus-visible:outline-2 focus-visible:-outline-offset-2"
>
	<div class="mb-4 flex items-center justify-between">
		<span
			class="pc-icon-shell border-border bg-muted text-muted-foreground relative flex size-11 items-center justify-center rounded-md border transition-[background-color,border-color,color] duration-200"
		>
			<Icon
				name={icon}
				size="24px"
				class="pc-icon transition-colors duration-200"
			/>
		</span>
		<span
			class="text-primary text-right font-mono text-xs tracking-widest uppercase"
		>
			{product}
		</span>
	</div>

	<p class="text-foreground mb-2 text-base leading-snug font-medium md:text-lg">
		{scenario}
	</p>
	<p
		class="text-muted-foreground mb-6 flex-1 text-sm leading-relaxed md:text-base"
	>
		{detail}
	</p>

	<span
		class="pc-cta text-muted-foreground inline-flex w-fit items-center gap-2 text-sm font-medium underline-offset-4 group-hover/product-card:underline"
	>
		{cta}
		<Icon
			name="ph:arrow-right"
			class="h-3.5 w-3.5 transition-transform duration-150 group-hover/product-card:translate-x-0.5"
		/>
	</span>
</a>

<style>
	.group\/product-card:hover .pc-icon-shell {
		border-color: color-mix(in srgb, var(--card-color) 30%, transparent);
		background-color: color-mix(in srgb, var(--card-color) 5%, transparent);
		color: var(--card-color);
	}
</style>
