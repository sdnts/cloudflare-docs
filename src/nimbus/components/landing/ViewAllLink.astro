---
import { Icon } from "astro-icon/components";

interface Props {
	href: string;
	class?: string;
}

const { href, class: className = "" } = Astro.props;
---

<a
	href={href}
	class:list={[
		"group text-primary decoration-primary/40 hidden shrink-0 items-center gap-1.5 text-sm font-medium underline-offset-4 hover:underline md:inline-flex",
		className,
	]}
>
	<slot />
	<Icon
		name="ph:caret-right"
		class="h-3 w-3 transition-transform duration-150 group-hover:translate-x-0.5"
	/>
</a>
