---
/**
 * Code — syntax-highlighted code block from a string prop.
 *
 *   <Code code={generated} lang="ts" />
 *   <Code code={...} lang="ts" meta='title="src/foo.ts" {1,3-5}' />
 */
import { Code as AstroCode } from "astro:components";
import { defaultCodeTransformers } from "nimbus-docs";

type Props = Parameters<typeof AstroCode>[0];
const rawProps = Astro.props as Props;
const usesNimbusDefaultThemes = !("theme" in rawProps) && !("themes" in rawProps);
const themed = usesNimbusDefaultThemes
  ? {
      ...rawProps,
      themes: { light: "github-light", dark: "github-dark" },
      defaultColor: false,
    }
  : rawProps;
const userTransformers = themed.transformers ?? [];
const props = {
  ...themed,
  transformers: defaultCodeTransformers({
    classTokens: usesNimbusDefaultThemes,
    beforeTitleTransformers: userTransformers,
  }),
};
---

<AstroCode {...props} />
