---
/**
 * TabItem — single tab panel in the Starlight-compatible `<Tabs>` usage.
 *
 * The `label` prop is read by `tabs.client.ts` to synthesize the matching
 * trigger button. Each TabItem becomes one `[data-nb-tabs-content]` panel.
 */
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  label: string;
}

const { label, class: className, ...attrs } = Astro.props;

if (!label) {
  throw new Error("Missing required `label` prop on `<TabItem>` component.");
}
---

<div
  role="tabpanel"
  data-nb-tabs-content
  data-nb-tab-label={label}
  class={cn(className)}
  {...attrs}
>
  <slot />
</div>
