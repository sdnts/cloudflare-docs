---
// Site-wide 404: splash, noindex; body supplies its own h1.
import SplashLayout from "~/layouts/SplashLayout.astro";
import FourOhFour from "~/components/404.astro";

export const prerender = true;
---

<SplashLayout title="404 - Page Not Found" noindex>
  <div class="mx-auto w-full max-w-[1120px] px-[max(1.5rem,4vw)] py-14">
    <FourOhFour />
  </div>
</SplashLayout>
