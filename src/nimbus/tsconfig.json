{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"baseUrl": ".",
		"target": "ESNext",
		"paths": {
			"~/assets/*": ["../assets/*"],
			"~/content/*": ["../content/*"],
			"~/*": ["./*"],
			"@/*": ["./*"]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	},
	"include": ["../../.astro/types.d.ts", "**/*"],
	"exclude": ["dist", "dist-nimbus"]
}
