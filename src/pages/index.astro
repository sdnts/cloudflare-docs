const props = {
	frontmatter: {
		title: "Cloudflare Developer Docs",
		description: "Connect, protect, and build everywhere.",
		template: "doc",
		tableOfContents: false,
	},
	sidebar,
	hasSidebar: true,
	hideBreadcrumbs: true,
	hideTitle: true,
	headings: [],
} as StarlightPageProps;
---

<StarlightPage {...props}>
	<div class="landing-root">
		<div class="relative">
			<FullPageLines />
			<StructuralGrid />
			<main
				class="relative z-10 mx-auto max-w-[1280px]"
				id="main-content"
				style="padding-inline: var(--l-section-pad); padding-top: var(--l-pad-top);"
			>
				<Hero />

				<BuildFromScratch />

				<AgentSetup />

				<ChangelogSection />

				<SecureSection />

				<AccelerateSection />

				<CommunityGrid />
			</main>
		</div>
	</div>
</StarlightPage>

<script>
	// Instant scroll to hash target on page load (no smooth animation).
	// Subsequent in-page clicks use CSS scroll-behavior: smooth.
	{
		const hash = window.location.hash;
		if (hash.length > 1) {
			let target: Element | null = null;
			let id = hash.slice(1);
			try {
				id = decodeURIComponent(id);
			} catch {
				// keep raw id when hash is malformed
			}
			target = document.getElementById(id);
			if (!target) {
				try {
					target = document.querySelector(hash);
				} catch {
					target = null;
				}
			}
			if (target) {
				// Temporarily disable smooth scrolling for the initial jump
				const html = document.documentElement;
				const prev = html.style.scrollBehavior;
				html.style.scrollBehavior = "auto";
				requestAnimationFrame(() => {
					target.scrollIntoView();
					// Restore after the frame so future clicks are smooth again
					requestAnimationFrame(() => {
						html.style.scrollBehavior = prev;
					});
				});
			}
		}
	}
</script>

<style is:global>
	/* Starlight layout overrides */
	.right-sidebar-container,
	mobile-starlight-toc {
		display: none;
	}

	.main-frame {
		padding-top: var(--sl-nav-height);
	}
	.main-pane {
		padding: 0;
		gap: 0;
		isolation: isolate;
		z-index: 0;
	}
	.content-panel {
		padding: 0;
		margin: 0;
		overflow: visible;
	}
	.sl-container {
		max-width: none;
		margin: 0;
		padding: 0;
		overflow: visible;
	}
	.sl-markdown-content {
		margin: 0;
		padding: 0;
		overflow: visible;
	}
	.sl-markdown-content > :first-child {
		margin-top: 0;
	}
	.sl-markdown-content
		:not(a, strong, em, del, span, input, code, br)
		+ :not(a, strong, em, del, span, input, code, br, :where(.not-content *)) {
		margin-top: 0;
	}

	/* Restore footer spacing — scoped to the landing page only */
	body:has(.landing-root) footer {
		margin-top: 0;
	}
	body:has(.landing-root) footer .custom-footer-section {
		position: relative;
		z-index: 1;
		max-width: 1280px;
		margin-inline: auto;
		padding-inline: var(--l-section-pad, 1.5rem);
		padding-bottom: 1.5rem;
		border-top: 1px solid var(--sl-color-gray-6);
		background-color: var(--sl-color-bg);
	}
</style>
